# Copy to .env and fill in from your Supabase project settings (Project Settings > API).
# These are the public/anon values — safe to expose in a client bundle, RLS
# enforces what the anon key can actually read/write (see supabase/migrations).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Secrets below are NOT read by Vite (no VITE_ prefix) — they belong in the
# Supabase Edge Function secrets (supabase secrets set KEY=value), never in
# this file's committed form or in any client-side code.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# SUPABASE_SERVICE_ROLE_KEY=
# ALLPRODUCTS_API_KEY=
